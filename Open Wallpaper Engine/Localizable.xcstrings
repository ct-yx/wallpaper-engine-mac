    "The updated app was downloaded, but this app folder is not writable. Move the app to a writable folder and try again." : { "localizations" : { "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已下载更新，但当前应用所在文件夹不可写入。请将应用移到可写入的文件夹后重试。" } } } },
